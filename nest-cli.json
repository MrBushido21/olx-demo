{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/olx/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "plugins": [
      "@nestjs/swagger"
    ],
    "webpack": true,
    "tsConfigPath": "apps/olx/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/olx",
  "projects": {
    "auth": {
      "type": "application",
      "root": "apps/auth",
      "entryFile": "main",
      "sourceRoot": "apps/auth/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth/tsconfig.app.json",
        "webpack": true
      }
    },
    "chats": {
      "type": "application",
      "root": "apps/chats",
      "entryFile": "main",
      "sourceRoot": "apps/chats/src",
      "compilerOptions": {
        "tsConfigPath": "apps/chats/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "listings": {
      "type": "application",
      "root": "apps/listings",
      "entryFile": "main",
      "sourceRoot": "apps/listings/src",
      "compilerOptions": {
        "tsConfigPath": "apps/listings/tsconfig.app.json"
      }
    },
    "olx": {
      "type": "application",
      "root": "apps/olx",
      "entryFile": "main",
      "sourceRoot": "apps/olx/src",
      "compilerOptions": {
        "tsConfigPath": "apps/olx/tsconfig.app.json"
      }
    },
    "users": {
      "type": "application",
      "root": "apps/users",
      "entryFile": "main",
      "sourceRoot": "apps/users/src",
      "compilerOptions": {
        "tsConfigPath": "apps/users/tsconfig.app.json"
      }
    }
  }
}